{
  "name": "@hitl-sdk/resolver-workflow-sdk",
  "version": "0.0.2",
  "description": "Vercel's Workflow SDK binding for hitl.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-lib.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hitl-sdk/hitl": "workspace:*",
    "workflow": "*"
  },
  "devDependencies": {
    "@hitl-sdk/hitl": "workspace:*",
    "@types/node": "^25.9.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "workflow": "latest"
  }
}
