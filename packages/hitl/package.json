      "default": "./src/testing.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
