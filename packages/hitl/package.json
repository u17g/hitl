{
  "name": "hitl",
  "version": "0.0.0",
  "description": "Human-in-the-loop as a typed, durable primitive for TypeScript workflows.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
