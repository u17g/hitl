{
  "name": "@hitl-sdk/state-pg",
  "version": "0.0.0",
  "description": "Postgres store for hitl. Bring your own pg-compatible pool.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "state-pg": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "peerDependencies": {
    "hitl": "workspace:*"
  },
  "devDependencies": {
    "hitl": "workspace:*",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.15.4",
    "esbuild": "^0.25.5",
    "pg-mem": "^3.0.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
