{
  "name": "@hitl-sdk/state-pg",
  "version": "0.0.2",
  "description": "Postgres store for hitl. Bring your own pg-compatible pool.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/u17g/hitl.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "state-pg": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-lib.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "peerDependencies": {
    "@hitl-sdk/hitl": "workspace:*"
  },
  "devDependencies": {
    "@hitl-sdk/hitl": "workspace:*",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.15.4",
    "pg-mem": "^3.0.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
