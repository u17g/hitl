{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "hitldev",
    "description": "Human-in-the-loop approval messages for workflows — Block Kit forms with Approve/Deny buttons.",
    "background_color": "#4A154B"
  },
  "features": {
    "bot_user": {
      "display_name": "hitldev",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": ["chat:write", "chat:write.public"]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://example.com/.well-known/hitldev/v1/slack"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
