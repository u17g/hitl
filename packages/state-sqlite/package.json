{
  "name": "@hitl/state-sqlite",
  "version": "0.0.0",
  "description": "SQLite store for hitl, built on node:sqlite with zero dependencies.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "state-sqlite": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hitl": "workspace:*"
  },
  "devDependencies": {
    "hitl": "workspace:*",
    "@types/node": "^25.9.3",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
