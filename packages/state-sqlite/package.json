{
  "name": "@hitl-sdk/state-sqlite",
  "version": "0.0.4",
  "description": "SQLite store for hitl, built on node:sqlite with zero dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/u17g/hitl.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "state-sqlite": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-lib.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hitl-sdk/hitl": "workspace:*"
  },
  "devDependencies": {
    "@hitl-sdk/hitl": "workspace:*",
    "@types/node": "^25.9.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
